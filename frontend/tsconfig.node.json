{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["electron-vite/node", "node"],
    "baseUrl": "."
  },
  "include": ["src/main/**/*", "src/preload/**/*", "src/shared/**/*", "src/tts-client/**/*"]
}
